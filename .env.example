# Police Intelligence System - Environment Variables
# Copy this file to .env and update with your actual values

# ============================================
# NEON DATABASE CONFIGURATION
# ============================================
# Get this from: https://console.neon.tech → Your Project → Connection Details
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.ap-south-1.aws.neon.tech/police_data?sslmode=require

# Alternative format (if using separate variables)
DB_HOST=ep-xxx-xxx.ap-south-1.aws.neon.tech
DB_PORT=5432
DB_NAME=police_data
DB_USER=your_username
DB_PASSWORD=your_password
DB_SSL_MODE=require

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_DIFFERENT_32_CHAR_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# APPLICATION SETTINGS
# ============================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-domain.com

# Upload settings
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=backend/uploads
PROCESSED_DIR=backend/processed
MASTER_DIR=backend/master

# ============================================
# EXTERNAL SERVICES
# ============================================
# InfoByIP URL for IP enrichment
INFOBYIP_URL=https://www.infobyip.com/ipbulklookup.php

# ============================================
# SECURITY SETTINGS
# ============================================
# Session timeout (seconds)
SESSION_TIMEOUT=900

# Rate limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_UPLOAD=10
RATE_LIMIT_API=30

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_DIR=/var/log/police-intel

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NUXT_PUBLIC_API_BASE=http://localhost:8000

# ============================================
# PRODUCTION SETTINGS (Optional)
# ============================================
# ENVIRONMENT=production
# DEBUG=false
# SENTRY_DSN=your_sentry_dsn_here
