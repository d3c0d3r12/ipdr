# Backend Environment Variables (.env)
# Copy this file to .env and fill values

# --- Server ---
APP_NAME=IPDR Tracking Hub
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=info

# --- Security / Auth ---
SECRET_KEY=change_this_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=4320  # 3 days
ALGORITHM=HS256

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database (NeonDB / PostgreSQL) ---
# Example: postgresql+psycopg2://USER:PASSWORD@HOST/DBNAME
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# --- Optional: SMTP (for email features, if added later) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Cloudflare / Bypass tuning ---
BYPASS_HEADLESS=true
BYPASS_VERBOSE=false

# --- File Storage (kept for compatibility; cloud-first recommended) ---
PROCESSED_DIR=backend/processed
TEMP_UPLOADS_DIR=backend/temp_uploads

# --- Rate limiting (SlowAPI) ---
RATE_LIMIT_EXEC=100/minute

# --- GeoLite2 (Offline Bulk Enrichment) ---
# Create a free MaxMind account, generate a license key, then run:
#   python setup_geolite2.py
MAXMIND_LICENSE_KEY=
GEOIP_CITY_DB=
GEOIP_ASN_DB=

# Optional
IPDR_WHOIS_RDAP=0
